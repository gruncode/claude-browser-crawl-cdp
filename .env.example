# Copy to .env and fill in. .env is git-ignored — never commit real values.

# --- toolkit config (optional; defaults shown) ---
CDP_PORT=9222
CDP_PROFILE=$HOME/.config/chrome-cdp
# CDP_PYTHON=./.venv/bin/python
# CHROME_BIN=/usr/bin/google-chrome
# CDP_SOCK=/tmp/cdp_repl.sock

# --- your own site credentials (examples) ---
# Used by your automation scripts via os.environ — not by the toolkit itself.
# SITE_USER=
# SITE_PASS=

# --- optional third-party services ---
# BRIGHTDATA_API_KEY=
